# Server
PORT=3000
SITE_URL=https://your-app.up.railway.app

# Session secret — generate a long random string for production
SESSION_SECRET=change-this-to-a-long-random-secret

# Meshulam payment gateway
MESHULAM_API_KEY=your-meshulam-api-key-here
MESHULAM_PAGE_ID=your-meshulam-page-id-here

# Email — Gmail App Password (not your regular password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
